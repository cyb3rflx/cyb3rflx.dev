---
import Button from "./Button.astro"
---

<section aria-label="Intro" class="flex flex-wrap-reverse items-center justify-between gap-12 pt-[clamp(48px,8vw,96px)] pb-[clamp(56px,8vw,104px)]">
    <div class="flex-[1_1_480px] min-w-[300px] flex flex-col items-start gap-5">
        <p class="font-mono text-[13px] tracking-[0.12em] text-accent-cyan uppercase">// junior devops engineer</p>
        <h1 class="text-[clamp(40px,6vw,64px)] leading-[1.05] font-bold tracking-[-0.02em] text-balance">Florian Steinert</h1>
        <p class="text-[clamp(18px,2.4vw,22px)] leading-[1.45] text-text-muted max-w-[34ch] text-pretty">I built a full-stack app and run it live on my own self-hosted Kubernetes cluster, from bare Linux server to automated CI/CD deployments.</p>
        <div class="flex flex-wrap items-center gap-4 mt-2">
            <Button link="https://www.linkedin.com/in/florian-steinert/" text="Connect on LinkedIn" />
            <a href="https://github.com/cyb3rflx" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-text font-semibold text-base px-5 py-[14px] border border-mid rounded-[10px] transition-all hover:border-text-muted focus-visible:[outline:2px_solid_#22D3EE] focus-visible:[outline-offset:3px]">GitHub ↗</a>
        </div>
    </div>
    <div class="flex-[0_1_340px] min-w-[260px] flex justify-center relative">
        <div aria-hidden="true" class="absolute inset-[8%] rounded-full blur-[24px] animate-[visorPulse_5s_ease-in-out_infinite] bg-[radial-gradient(circle,rgba(34,211,238,0.22),rgba(244,63,94,0.08)_55%,transparent_72%)]"></div>
        <img src="/avatar.png" alt="CYB3RFLX avatar — cyberpunk robot helmet with glowing cyan visor" width="340" height="340" class="relative w-[min(340px,72vw)] h-auto rounded-full border border-border shadow-[0_0_0_1px_rgba(34,211,238,0.25),0_0_48px_rgba(34,211,238,0.12)]" />
    </div>
</section>
